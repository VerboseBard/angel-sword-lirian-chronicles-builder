{
  "name": "angel-sword-lirian-chronicles-builder",
  "version": "2.13.0",
  "private": true,
  "description": "Web-ready Angel Sword Lyrian Chronicles character builder, Beta 2.13 public release.",
  "type": "module",
  "scripts": {
    "build": "esbuild src/js/main.js --bundle --format=iife --global-name=LyrianApp --target=es2020,safari15 --minify --sourcemap --outfile=assets/app.bundle.js && node scripts/check-bundle-compat.mjs",
    "start": "node scripts/server.mjs",
    "serve": "node scripts/server.mjs",
    "audit:minmax": "node scripts/audit-minmax-cascades.mjs",
    "test:rules0131": "npm run build && node scripts/test-rules-0131.mjs",
    "test": "npm run build && node scripts/test-cross-browser.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.25.5",
    "playwright": "^1.60.0"
  }
}
